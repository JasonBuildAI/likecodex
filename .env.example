# LikeCodex environment variables

# LLM
LIKECODEX_LLM_PROVIDER=openai
LIKECODEX_LLM_MODEL=gpt-4o
LIKECODEX_LLM_API_KEY=
OPENAI_API_KEY=

# Engine
LIKECODEX_ENGINE_HOST=127.0.0.1
LIKECODEX_ENGINE_PORT=9090
LIKECODEX_ENGINE_URL=http://127.0.0.1:9090
LIKECODEX_WORKING_DIR=.

# Server
LIKECODEX_API_TOKEN=
LIKECODEX_SANDBOX_URL=http://127.0.0.1:8080/execute
LIKECODEX_INDEXER_URL=http://127.0.0.1:8080/index/search

# Agent behavior
LIKECODEX_APPROVAL_MODE=auto
LIKECODEX_ENABLE_PLANNER=false
LIKECODEX_ENABLE_MCP=false
LIKECODEX_MEMORY_PATH=.likecodex/memory.jsonl
LIKECODEX_SESSION_DB=.likecodex/sessions.db

# Web
NEXT_PUBLIC_API_BASE=/api
