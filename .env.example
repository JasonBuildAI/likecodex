# LikeCodex environment variables (DeepSeek V4)

# DeepSeek LLM
LIKECODEX_LLM_PROVIDER=deepseek
LIKECODEX_LLM_MODEL=deepseek-v4-flash
LIKECODEX_LLM_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
LIKECODEX_LLM_API_KEY=

# DeepSeek options
# Set to true for thinking mode (complex reasoning tasks)
LIKECODEX_DEEPSEEK_THINKING=false

# Alternative LLM Providers (OpenAI-compatible)
LIKECODEX_OPENAI_API_KEY=
LIKECODEX_OPENAI_BASE_URL=https://api.openai.com/v1
LIKECODEX_OPENAI_MODEL=gpt-4o

# Anthropic Claude (optional)
LIKECODEX_ANTHROPIC_API_KEY=
LIKECODEX_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Model Router
LIKECODEX_PLANNER_MODEL=deepseek-v4-pro
LIKECODEX_EXECUTOR_MODEL=deepseek-v4-flash
LIKECODEX_SMART_ROUTING=true
LIKECODEX_MAX_COST_PER_SESSION=0.50

# Engine
LIKECODEX_ENGINE_HOST=127.0.0.1
LIKECODEX_ENGINE_PORT=9090
LIKECODEX_ENGINE_URL=http://127.0.0.1:9090
LIKECODEX_WORKING_DIR=.

# Server
LIKECODEX_API_TOKEN=
LIKECODEX_SANDBOX_URL=http://127.0.0.1:8080/execute
LIKECODEX_INDEXER_URL=http://127.0.0.1:8080/index/search

# Agent behavior
LIKECODEX_APPROVAL_MODE=auto
LIKECODEX_ENABLE_PLANNER=true
LIKECODEX_ENABLE_MCP=true
LIKECODEX_ENABLE_BACKGROUND_AGENT=true
LIKECODEX_ENABLE_DREAMING=true
LIKECODEX_ENABLE_MULTIMODAL=true
LIKECODEX_ENABLE_BROWSER=true
LIKECODEX_MEMORY_PATH=.likecodex/memory.jsonl
LIKECODEX_SESSION_DB=.likecodex/sessions.db
LIKECODEX_MAX_PARALLEL_SUBAGENTS=8
LIKECODEX_SUBAGENT_NESTING_DEPTH=3

# Browser Preview
LIKECODEX_BROWSER_HEADLESS=true
LIKECODEX_BROWSER_PORT=9222

# Collaboration
LIKECODEX_COLLAB_ENABLED=false
LIKECODEX_COLLAB_WS_URL=ws://127.0.0.1:8080/ws/collaboration

# Telemetry & Performance
LIKECODEX_TELEMETRY_ENABLED=false
LIKECODEX_METRICS_PORT=9091
LIKECODEX_ENABLE_OPENTELEMETRY=false

# Web
NEXT_PUBLIC_API_BASE=/api
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8080
NEXT_PUBLIC_ENABLE_COLLAB=false
NEXT_PUBLIC_ENABLE_BROWSER_PREVIEW=true
NEXT_PUBLIC_ENABLE_MULTIMODAL=true
# LikeCodex environment variables (DeepSeek V4)

# DeepSeek LLM
LIKECODEX_LLM_PROVIDER=deepseek
LIKECODEX_LLM_MODEL=deepseek-v4-flash
LIKECODEX_LLM_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
LIKECODEX_LLM_API_KEY=

# DeepSeek options
# Set to true for thinking mode (complex reasoning tasks)
LIKECODEX_DEEPSEEK_THINKING=false

# Engine
LIKECODEX_ENGINE_HOST=127.0.0.1
LIKECODEX_ENGINE_PORT=9090
LIKECODEX_ENGINE_URL=http://127.0.0.1:9090
LIKECODEX_WORKING_DIR=.

# Server
LIKECODEX_API_TOKEN=
LIKECODEX_SANDBOX_URL=http://127.0.0.1:8080/execute
LIKECODEX_INDEXER_URL=http://127.0.0.1:8080/index/search

# Agent behavior
LIKECODEX_APPROVAL_MODE=auto
LIKECODEX_ENABLE_PLANNER=false
LIKECODEX_ENABLE_MCP=false
LIKECODEX_MEMORY_PATH=.likecodex/memory.jsonl
LIKECODEX_SESSION_DB=.likecodex/sessions.db

# Web
NEXT_PUBLIC_API_BASE=/api
