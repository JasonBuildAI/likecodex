{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LikeCodex",
  "version": "0.1.0",
  "identifier": "dev.likecodex.desktop",
  "build": {
    "beforeDevCommand": "cd ../../web && npm run dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "cd ../../web && npm run build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "LikeCodex",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
